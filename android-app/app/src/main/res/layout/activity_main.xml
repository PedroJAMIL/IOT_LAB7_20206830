<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/padding_screen">

        <!-- Tarjeta de estado dinámica -->
        <LinearLayout
            android:id="@+id/cardEstado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_card_green">

            <TextView
                android:id="@+id/tvTituloEstado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/estado_activo"
                android:textColor="@color/bici_green"
                android:textStyle="bold"
                android:textSize="14sp"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/tvCountdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="120s"
                android:textColor="@color/bici_green"
                android:textSize="@dimen/text_countdown"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tvMensajePrincipal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/texto_candado_energizado"
                android:textColor="@color/bici_green"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvMensajeSecundario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/texto_retire_bicicleta"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSolicitarDesbloqueo"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/btn_solicitar_desbloqueo"
                android:textSize="14sp"
                android:textStyle="bold"
                android:backgroundTint="@color/bici_red"
                android:layout_marginTop="24dp"
                app:cornerRadius="@dimen/corner_radius"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Datos del usuario debajo (informativo) -->
        <TextView
            android:id="@+id/tvInfoUsuario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="32dp"
            android:gravity="center" />
    </LinearLayout>
</ScrollView>
